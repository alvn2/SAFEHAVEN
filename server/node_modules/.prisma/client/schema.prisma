generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
  VOLUNTEER_PENDING
  VOLUNTEER_APPROVED
}

enum VolunteerTrack {
  PEER_LISTENER
  PROFESSIONAL
}

enum VolunteerRole {
  licensed
  intern
  listener
}

model User {
  id                String   @id @default(uuid())
  username          String   @unique
  passphraseHash    String // Hashed password (never plain)
  recoveryKey       String? // Encrypted blob of the recovery phrase
  role              Role     @default(USER)
  agreedToTerms     Boolean  @default(false)
  lastActive        DateTime @default(now())
  inactivityEnabled Boolean  @default(true)
  status            String   @default("ACTIVE") // ACTIVE, SUSPENDED
  createdAt         DateTime @default(now())

  // Relations
  journalEntries   JournalEntry[]
  safetyPlan       SafetyPlan?
  volunteer        VolunteerProfile?
  sentMessages     Message[]
  conversations    ConversationParticipant[]
  events           Event[]
  communityGroups  CommunityGroup[]
  quoteSuggestions QuoteSuggestion[]
  modApplications  ModeratorApplication[]
}

model VolunteerProfile {
  id            String         @id @default(uuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  track         VolunteerTrack @default(PEER_LISTENER)
  name          String
  photo         String?
  role          VolunteerRole
  qualification String
  topics        String[] // Stored as JSON array in Postgres
  location      String
  whatsapp      String
  telegram      String?
  languages     String[]
  isOnline      Boolean        @default(false)
  verified      Boolean        @default(false)
  bio           String
  views         Int            @default(0)
  chats         Int            @default(0)
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  mood      Int
  energy    Int
  sleep     Int
  entry     String // ENCRYPTED BLOB (Ciphertext)
  audioData String? // ENCRYPTED BASE64 BLOB
  tags      String[]
  isDraft   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SafetyPlan {
  id                   String @id @default(uuid())
  userId               String @unique
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  warningSigns         String // ENCRYPTED
  copingStrategies     String // ENCRYPTED
  safeContacts         String // ENCRYPTED
  professionalContacts String // ENCRYPTED
  environmentChanges   String // ENCRYPTED
}

model ForumPost {
  id           String         @id @default(uuid())
  author       String // Anonymous Display Name
  title        String
  body         String
  category     String
  hugs         Int            @default(0)
  isTriggering Boolean        @default(false)
  isFlagged    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  comments     ForumComment[]
}

model ForumComment {
  id        String         @id @default(uuid())
  postId    String
  post      ForumPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  children  ForumComment[] @relation("CommentReplies")
  author    String
  body      String
  hugs      Int            @default(0)
  createdAt DateTime       @default(now())
}

// --- Chat System ---

model Conversation {
  id            String   @id @default(uuid())
  type          String // 'dm' or 'group'
  name          String?
  avatar        String?
  lastMessage   String? // Encrypted snippet or system message
  lastMessageAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  hasUnread      Boolean      @default(false)
  joinedAt       DateTime     @default(now())

  @@unique([userId, conversationId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  senderName     String // Snapshot of anonymous name
  content        String // ENCRYPTED BLOB
  createdAt      DateTime     @default(now())
}

// --- Admin / Content / Community ---

model Resource {
  id          String   @id @default(uuid())
  type        String // ARTICLE, BOOK, VIDEO, QUOTE
  title       String
  description String?
  author      String? // or presenter
  url         String? // links/video URLs
  imageUrl    String? // cover/thumbnail
  status      String   @default("APPROVED") // PENDING, APPROVED, REJECTED
  category    String?
  readTime    Int?
  createdAt   DateTime @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  link        String?
  organizer   String?
  status      String   @default("PENDING") // PENDING, APPROVED
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
  createdAt   DateTime @default(now())
}

model CommunityGroup {
  id           String   @id @default(uuid())
  name         String
  description  String
  category     String
  link         String?
  platform     String?
  privacy      String   @default("PUBLIC") // PUBLIC, PRIVATE
  ownerId      String
  owner        User     @relation(fields: [ownerId], references: [id])
  safetyRating String   @default("Pending Review") // Unverified, Verified Safe
  status       String   @default("PENDING") // PENDING, APPROVED
  createdAt    DateTime @default(now())
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String
  category    String
  link        String
  status      String   @default("PENDING") // PENDING, APPROVED
  createdAt   DateTime @default(now())
}

model QuoteSuggestion {
  id            String   @id @default(uuid())
  text          String
  author        String
  submittedById String
  submittedBy   User     @relation(fields: [submittedById], references: [id])
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model ModeratorApplication {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  reason    String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}

model VolunteerApplication {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  role          String
  qualification String
  experience    String
  licenseNumber String?
  status        String   @default("pending") // pending, approved, rejected
  submittedAt   DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  targetIdHash String
  details      String
  timestamp    DateTime @default(now())
}
